# =============================================================================
# AEGIS AI — Environment Configuration Template
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=changeme_strong_password

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_strong_password

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=aegis

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=aegis-platform

# --- JWT Auth ---
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=changeme_generate_with_openssl
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Service URLs (internal) ---
GATEWAY_URL=http://gateway:8000
ASSET_DISCOVERY_URL=http://asset-discovery:8001
TELEMETRY_URL=http://telemetry-collector:8002
THREAT_INTEL_URL=http://threat-intel:8003
DETECTION_ENGINE_URL=http://detection-engine:8004
AGENT_ORCHESTRATOR_URL=http://agent-orchestrator:8005
KNOWLEDGE_GRAPH_URL=http://knowledge-graph:8006
INVESTIGATION_URL=http://investigation:8007
RESPONSE_ENGINE_URL=http://response-engine:8008
APPROVAL_WORKFLOW_URL=http://approval-workflow:8009

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# --- External Threat Intel APIs (optional, add keys when available) ---
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
NVD_API_KEY=

# --- Notifications ---
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=aegis@yourdomain.com

# --- Platform ---
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
